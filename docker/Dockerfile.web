FROM node:22-slim AS base
WORKDIR /app
COPY apps/web/package.json ./
RUN npm install

FROM base AS dev
COPY apps/web .
CMD ["npm", "run", "dev"]

FROM base AS build
COPY apps/web .
RUN npm run build

FROM nginx:alpine AS prod
COPY --from=build /app/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80